{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "bump-minor-pre-major": true,
  "packages": {
    ".": {
      "package-name": "injury-risk",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug fixes"
    },
    {
      "type": "refactor",
      "section": "Refactoring"
    },
    {
      "type": "ml",
      "section": "Modelling"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "ci",
      "section": "CI/CD"
    },
    {
      "type": "build",
      "section": "Build & dependencies"
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": false
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Chores",
      "hidden": true
    }
  ],
  "include-component-in-tag": false
}
